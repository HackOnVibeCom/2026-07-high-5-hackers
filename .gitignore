# Root-level ignores for the HackOnVibe team repo.
# The app itself lives in stellar-launch-ai-main/ and has its own .gitignore too.

# Dependencies
node_modules/

# Build output / framework caches
dist/
build/
out/
.output/
.tanstack/
.nitro/
.vinxi/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Wrangler / Cloudflare local state (never commit — it is machine-local cache)
.wrangler/

# Secrets — real values live only in Cloudflare Pages env vars / local .dev.vars
.dev.vars
*.local

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
